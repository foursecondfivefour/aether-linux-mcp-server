# AETHER_02 — Feature Gates
# 0 = disabled (safe, default)
# 1 = enabled (administrator accepts risk)

# === Critically dangerous operations ===
# Kexec — load new kernel via kexec
AETHER_KEXEC_LOAD=0
# Module Load — load/unload kernel modules
AETHER_MODULE_LOAD=0
# BPF Load — load BPF programs
AETHER_BPF_LOAD=0

# === Sensitive security operations ===
# Ptrace — ptrace attach to non-child processes
AETHER_PTRACE_ATTACH=0
# Namespace Create — creating new namespaces, namespace_enter
AETHER_NAMESPACE_CREATE=0
# Offline Mount — mount filesystems from raw block devices
AETHER_OFFLINE_MOUNT=0

# === Disk operations ===
# Partition Edit — create/delete/resize disk partitions
AETHER_PARTITION_EDIT=0

# === Privilege operations ===
# Token Manipulation — capability changes, setuid/setgid manipulation
AETHER_TOKEN_MANIPULATION=0
